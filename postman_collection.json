{
  "info": {
    "name": "Notes App API",
    "description": "Complete Postman collection for the Notes App REST API. \n\n**Setup:**\n1. Set the `base_url` collection variable to your server (e.g. `http://localhost:5000`)\n2. Run **Register User** → then **Login User** (token is saved automatically)\n3. All protected requests will use the saved token\n\n**Base URL:** `{{base_url}}/api`",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_postman_id": "notes-app-api-collection-v1"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:5000",
      "type": "string",
      "description": "Backend server base URL"
    },
    {
      "key": "token",
      "value": "",
      "type": "string",
      "description": "JWT token – auto-set after Login"
    },
    {
      "key": "note_id",
      "value": "",
      "type": "string",
      "description": "Note ID – set manually or auto-set after Create Note"
    }
  ],
  "item": [
    {
      "name": "Health",
      "description": "Server health check endpoint",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/health",
              "host": ["{{base_url}}"],
              "path": ["api", "health"]
            },
            "description": "Check if the server is running. No authentication required."
          },
          "response": [
            {
              "name": "Server Running",
              "status": "OK",
              "code": 200,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"success\": true,\n  \"message\": \"Server is running\",\n  \"timestamp\": \"2026-05-24T07:00:00.000Z\"\n}"
            }
          ]
        }
      ]
    },
    {
      "name": "Auth",
      "description": "User registration, login, and profile endpoints",
      "item": [
        {
          "name": "Register User",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"John Doe\",\n  \"email\": \"john@example.com\",\n  \"password\": \"secret123\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/api/users/register",
              "host": ["{{base_url}}"],
              "path": ["api", "users", "register"]
            },
            "description": "Register a new user account. Returns user data (no token). Rate limited to 20 requests/15min."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "pm.test('Success true', () => {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.success).to.be.true;",
                  "  pm.expect(json.data).to.have.property('_id');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "response": [
            {
              "name": "User Registered",
              "status": "Created",
              "code": 201,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"success\": true,\n  \"message\": \"User registered successfully\",\n  \"data\": {\n    \"_id\": \"665f1a2b3c4d5e6f7a8b9c0d\",\n    \"name\": \"John Doe\",\n    \"email\": \"john@example.com\",\n    \"createdAt\": \"2026-05-24T10:00:00.000Z\"\n  }\n}"
            },
            {
              "name": "Duplicate Email",
              "status": "Bad Request",
              "code": 400,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"success\": false,\n  \"message\": \"User with this email already exists\"\n}"
            },
            {
              "name": "Validation Error",
              "status": "Bad Request",
              "code": 400,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"success\": false,\n  \"message\": \"Name is required, Valid email is required, Password must be at least 6 characters\"\n}"
            }
          ]
        },
        {
          "name": "Login User",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john@example.com\",\n  \"password\": \"secret123\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/api/users/login",
              "host": ["{{base_url}}"],
              "path": ["api", "users", "login"]
            },
            "description": "Login with email and password. Returns a JWT token. Rate limited to 20 requests/15min.\n\nThe test script automatically saves the token to the `token` collection variable."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Token received', () => {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.success).to.be.true;",
                  "  pm.expect(json.token).to.be.a('string');",
                  "  // Auto-save token for subsequent requests",
                  "  pm.collectionVariables.set('token', json.token);",
                  "  console.log('Token saved:', json.token.substring(0, 20) + '...');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "response": [
            {
              "name": "Login Successful",
              "status": "OK",
              "code": 200,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"success\": true,\n  \"message\": \"Login successful\",\n  \"token\": \"eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpZCI6IjY2NWYxYTJiM2M0ZDVlNmY3YThiOWMwZCIsImlhdCI6MTcxNjU0NzYwMCwiZXhwIjoxNzE3MTUyNDAwfQ.example\",\n  \"data\": {\n    \"_id\": \"665f1a2b3c4d5e6f7a8b9c0d\",\n    \"name\": \"John Doe\",\n    \"email\": \"john@example.com\",\n    \"role\": \"user\"\n  }\n}"
            },
            {
              "name": "Invalid Credentials",
              "status": "Unauthorized",
              "code": 401,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"success\": false,\n  \"message\": \"Invalid email or password\"\n}"
            }
          ]
        },
        {
          "name": "Get Profile",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/api/users/profile",
              "host": ["{{base_url}}"],
              "path": ["api", "users", "profile"]
            },
            "description": "Get the profile of the currently logged-in user. Requires Bearer token."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Profile data returned', () => {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.success).to.be.true;",
                  "  pm.expect(json.data).to.have.property('email');",
                  "  pm.expect(json.data).to.have.property('role');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "response": [
            {
              "name": "Profile Retrieved",
              "status": "OK",
              "code": 200,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"success\": true,\n  \"data\": {\n    \"_id\": \"665f1a2b3c4d5e6f7a8b9c0d\",\n    \"name\": \"John Doe\",\n    \"email\": \"john@example.com\",\n    \"role\": \"user\",\n    \"createdAt\": \"2026-05-24T10:00:00.000Z\"\n  }\n}"
            },
            {
              "name": "Unauthorized",
              "status": "Unauthorized",
              "code": 401,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"success\": false,\n  \"message\": \"Not authorized, no token provided\"\n}"
            }
          ]
        }
      ]
    },
    {
      "name": "Notes",
      "description": "Protected notes CRUD endpoints. All require Bearer token.",
      "item": [
        {
          "name": "Get All Notes",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/api/notes",
              "host": ["{{base_url}}"],
              "path": ["api", "notes"]
            },
            "description": "Get all notes belonging to the currently authenticated user. Returns notes sorted by creation date (newest first)."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Notes array returned', () => {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.success).to.be.true;",
                  "  pm.expect(json.data).to.be.an('array');",
                  "  pm.expect(json).to.have.property('count');",
                  "  // Save first note ID if available",
                  "  if (json.data.length > 0) {",
                  "    pm.collectionVariables.set('note_id', json.data[0]._id);",
                  "  }",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "response": [
            {
              "name": "Notes Retrieved",
              "status": "OK",
              "code": 200,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"success\": true,\n  \"count\": 1,\n  \"data\": [\n    {\n      \"_id\": \"665f1a2b3c4d5e6f7a8b9c0e\",\n      \"title\": \"My first note\",\n      \"content\": \"This is the note content\",\n      \"createdBy\": \"665f1a2b3c4d5e6f7a8b9c0d\",\n      \"createdAt\": \"2026-05-24T10:30:00.000Z\",\n      \"updatedAt\": \"2026-05-24T10:30:00.000Z\"\n    }\n  ]\n}"
            }
          ]
        },
        {
          "name": "Create Note",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"My first note\",\n  \"content\": \"This is the note content. Notes can be anything you want to remember.\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/api/notes",
              "host": ["{{base_url}}"],
              "path": ["api", "notes"]
            },
            "description": "Create a new note. The note is automatically associated with the logged-in user."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "pm.test('Note created', () => {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.success).to.be.true;",
                  "  pm.expect(json.data).to.have.property('_id');",
                  "  pm.expect(json.data).to.have.property('title');",
                  "  // Auto-save note ID for subsequent requests",
                  "  pm.collectionVariables.set('note_id', json.data._id);",
                  "  console.log('Note ID saved:', json.data._id);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "response": [
            {
              "name": "Note Created",
              "status": "Created",
              "code": 201,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"success\": true,\n  \"message\": \"Note created successfully\",\n  \"data\": {\n    \"_id\": \"665f1a2b3c4d5e6f7a8b9c0e\",\n    \"title\": \"My first note\",\n    \"content\": \"This is the note content.\",\n    \"createdBy\": \"665f1a2b3c4d5e6f7a8b9c0d\",\n    \"createdAt\": \"2026-05-24T10:30:00.000Z\",\n    \"updatedAt\": \"2026-05-24T10:30:00.000Z\"\n  }\n}"
            },
            {
              "name": "Validation Error",
              "status": "Bad Request",
              "code": 400,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"success\": false,\n  \"message\": \"Title is required, Content is required\"\n}"
            }
          ]
        },
        {
          "name": "Get Note by ID",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/api/notes/{{note_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "notes", "{{note_id}}"]
            },
            "description": "Get a single note by its MongoDB ObjectId. Only the note owner or an admin can access it."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Single note returned', () => {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.success).to.be.true;",
                  "  pm.expect(json.data).to.have.property('_id');",
                  "  pm.expect(json.data).to.have.property('title');",
                  "  pm.expect(json.data).to.have.property('content');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "response": [
            {
              "name": "Note Found",
              "status": "OK",
              "code": 200,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"success\": true,\n  \"data\": {\n    \"_id\": \"665f1a2b3c4d5e6f7a8b9c0e\",\n    \"title\": \"My first note\",\n    \"content\": \"This is the note content.\",\n    \"createdBy\": \"665f1a2b3c4d5e6f7a8b9c0d\",\n    \"createdAt\": \"2026-05-24T10:30:00.000Z\",\n    \"updatedAt\": \"2026-05-24T10:30:00.000Z\"\n  }\n}"
            },
            {
              "name": "Note Not Found",
              "status": "Not Found",
              "code": 404,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"success\": false,\n  \"message\": \"Note not found\"\n}"
            },
            {
              "name": "Forbidden",
              "status": "Forbidden",
              "code": 403,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"success\": false,\n  \"message\": \"Not authorized to modify this note\"\n}"
            }
          ]
        },
        {
          "name": "Update Note",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Updated note title\",\n  \"content\": \"Updated note content with more details.\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/api/notes/{{note_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "notes", "{{note_id}}"]
            },
            "description": "Update a note's title and/or content. At least one field (title or content) must be provided. Only the note owner or an admin can update it."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Note updated', () => {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.success).to.be.true;",
                  "  pm.expect(json.message).to.equal('Note updated successfully');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "response": [
            {
              "name": "Note Updated",
              "status": "OK",
              "code": 200,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"success\": true,\n  \"message\": \"Note updated successfully\",\n  \"data\": {\n    \"_id\": \"665f1a2b3c4d5e6f7a8b9c0e\",\n    \"title\": \"Updated note title\",\n    \"content\": \"Updated note content with more details.\",\n    \"createdBy\": \"665f1a2b3c4d5e6f7a8b9c0d\",\n    \"createdAt\": \"2026-05-24T10:30:00.000Z\",\n    \"updatedAt\": \"2026-05-24T11:00:00.000Z\"\n  }\n}"
            },
            {
              "name": "Missing Update Fields",
              "status": "Bad Request",
              "code": 400,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"success\": false,\n  \"message\": \"Please provide title or content to update\"\n}"
            }
          ]
        },
        {
          "name": "Delete Note",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/api/notes/{{note_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "notes", "{{note_id}}"]
            },
            "description": "Permanently delete a note. Only the note owner or an admin can delete it."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Note deleted', () => {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.success).to.be.true;",
                  "  pm.expect(json.message).to.equal('Note deleted successfully');",
                  "  // Clear saved note ID",
                  "  pm.collectionVariables.set('note_id', '');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "response": [
            {
              "name": "Note Deleted",
              "status": "OK",
              "code": 200,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"success\": true,\n  \"message\": \"Note deleted successfully\"\n}"
            },
            {
              "name": "Forbidden",
              "status": "Forbidden",
              "code": 403,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"success\": false,\n  \"message\": \"Not authorized to modify this note\"\n}"
            }
          ]
        }
      ]
    },
    {
      "name": "Admin",
      "description": "Admin-only endpoints. Requires Bearer token AND admin role.",
      "item": [
        {
          "name": "Get All Users (Admin)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/api/admin/users",
              "host": ["{{base_url}}"],
              "path": ["api", "admin", "users"]
            },
            "description": "Get a list of all registered users. Requires the logged-in user to have `role: \"admin\"`.\n\nTo create an admin user, manually update the `role` field in MongoDB:\n```\ndb.users.updateOne({ email: 'admin@example.com' }, { $set: { role: 'admin' } })\n```"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200 or 403', () => {",
                  "  pm.expect(pm.response.code).to.be.oneOf([200, 403]);",
                  "});",
                  "if (pm.response.code === 200) {",
                  "  pm.test('Users list returned', () => {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.success).to.be.true;",
                  "    pm.expect(json.data).to.be.an('array');",
                  "  });",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "response": [
            {
              "name": "All Users (Admin)",
              "status": "OK",
              "code": 200,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"success\": true,\n  \"count\": 2,\n  \"data\": [\n    {\n      \"_id\": \"665f1a2b3c4d5e6f7a8b9c0d\",\n      \"name\": \"John Doe\",\n      \"email\": \"john@example.com\",\n      \"role\": \"user\",\n      \"createdAt\": \"2026-05-24T10:00:00.000Z\"\n    },\n    {\n      \"_id\": \"665f1a2b3c4d5e6f7a8b9c0f\",\n      \"name\": \"Admin User\",\n      \"email\": \"admin@example.com\",\n      \"role\": \"admin\",\n      \"createdAt\": \"2026-05-23T08:00:00.000Z\"\n    }\n  ]\n}"
            },
            {
              "name": "Forbidden (Not Admin)",
              "status": "Forbidden",
              "code": 403,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"success\": false,\n  \"message\": \"Not authorized, admin access required\"\n}"
            }
          ]
        }
      ]
    }
  ]
}
